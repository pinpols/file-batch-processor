# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Server
SERVER_PORT=8011

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/file_batch
SPRING_DATASOURCE_USERNAME=filebatch
SPRING_DATASOURCE_PASSWORD=replace_me

# Batch alert thresholds
BATCH_ALERT_ENABLED=true
BATCH_ALERT_FAILURE_RATE_THRESHOLD=0.2
BATCH_ALERT_DLQ_BACKLOG_THRESHOLD=100
BATCH_ALERT_MIN_THROUGHPUT_RPS_THRESHOLD=5
BATCH_ALERT_WEBHOOK_ENABLED=false
BATCH_ALERT_WEBHOOK_URL=

# JVM
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75 -XX:+ExitOnOutOfMemoryError
