# Application profile
SPRING_PROFILES_ACTIVE=prod

# Database
POSTGRES_DB=file_batch
POSTGRES_USER=filebatch
POSTGRES_PASSWORD=replace_me

# Orchestration source
CONFIG_SOURCE=db
CLUSTER_MODE=custom
CLUSTER_INSTANCE_ID=

# Alerting
BATCH_ALERT_ENABLED=true
BATCH_ALERT_WEBHOOK_ENABLED=false
BATCH_ALERT_WEBHOOK_URL=

# Ops console security
OPS_SECURITY_ENABLED=true
OPS_VIEWER_USERNAME=viewer
OPS_VIEWER_PASSWORD={noop}replace_me_viewer
OPS_OPERATOR_USERNAME=operator
OPS_OPERATOR_PASSWORD={noop}replace_me_operator
OPS_ADMIN_USERNAME=admin
OPS_ADMIN_PASSWORD={noop}replace_me_admin

# JVM
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75 -XX:+ExitOnOutOfMemoryError

# Logging (optional)
LOGGING_FILE_NAME=/app/logs/application.log
APP_LOG_LEVEL=INFO

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=replace_me_grafana
