# 开发环境配置

# ================================
# 数据库配置
# ================================
POSTGRES_DB=file_batch
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ================================
# 应用配置
# ================================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8011

# JVM 配置
JAVA_OPTS=--XX:+UseContainerSupport -XX:MaxRAMPercentage=75 -XX:+UseG1GC -Xdebug

# ================================
# 调度器配置
# ================================
SCHEDULER_POOL_SIZE=2
CONFIG_SOURCE=yaml

# ================================
# 日志配置
# ================================
LOG_LEVEL=DEBUG
APP_LOG_LEVEL=DEBUG

# ================================
# 集群配置
# ================================
CLUSTER_MODE=custom
CLUSTER_INSTANCE_ID=file-batch-dev-$(hostname)

# ================================
# 功能开关
# ================================
MISFIRE_ENABLED=true
MISFIRE_DETECTION_WINDOW_MS=300000
CALENDAR_EXCLUSION_ENABLED=true

# ================================
# 监控配置
# ================================
BATCH_ALERT_ENABLED=true
BATCH_ALERT_WEBHOOK_ENABLED=false
